# ─── SQL Query Lab Backend — Production Environment ──────────────────────────
#
# Copy to .env and fill in your values.
# These are loaded by the backend via dotenv/config.
#
# NEVER commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# The origin of your Vercel frontend (for CORS headers)
ALLOWED_ORIGIN=https://learn-sql-practice.vercel.app

# ── Encryption ────────────────────────────────────────────────────────────────
# Master password used to encrypt/decrypt stored SQL Server credentials.
# Generate a strong random string: openssl rand -hex 32
# The backend needs this at runtime to decrypt saved connections.
MASTER_PASSWORD=your-super-secret-master-password-here

# ── Optional: Logging ─────────────────────────────────────────────────────────
# NODE_ENV=production  (already set in Dockerfile)
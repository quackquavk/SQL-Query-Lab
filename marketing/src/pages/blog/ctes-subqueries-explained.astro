---
import Layout from '../../layouts/Layout.astro';

const publishDate = '2026-05-22';
const modifiedDate = '2026-06-02';

const faqItems = [
  {
    question: 'What is the difference between a subquery and a CTE?',
    answer: 'A subquery is an inline query embedded within another SQL statement — it cannot be referenced by name elsewhere in the query. A CTE (Common Table Expression) is a named subquery defined before the main query using WITH, making it reusable within the same query and far more readable for complex chains.',
  },
  {
    question: 'When should I use a correlated subquery vs a CTE?',
    answer: 'Use a correlated subquery when you need to evaluate an expression for each row of the outer query (like checking existence or finding a per-row maximum). Use a CTE when you want to break a complex query into named, readable steps or when multiple parts of the query need the same intermediate result.',
  },
  {
    question: 'Can CTEs be recursive?',
    answer: 'Yes. A recursive CTE uses a UNION ALL with a base case and a recursive case that references itself. It is ideal for traversing hierarchies (org charts, file systems, bill-of-materials) and generating sequences without a numbers table.',
  },
  {
    question: 'Do CTEs improve query performance?',
    answer: 'Not inherently. A CTE is syntactic sugar — the query optimizer typically inlines it the same way it handles a subquery. However, CTEs can improve performance indirectly by making complex queries easier for the optimizer to read and by enabling materialization hints in some databases.',
  },
  {
    question: 'What is a scalar subquery and when is it useful?',
    answer: 'A scalar subquery returns exactly one column and one row. It can be used anywhere a single value is expected — in SELECT, WHERE, or HAVING clauses. Use it when you need a single computed value per row, like the count of related records or the maximum from another table.',
  },
];

const codeExamples = {
  basicCte: `<code>-- CTE: name the intermediate step
WITH high_earners AS (
  SELECT employee_name, department, salary
  FROM employees
  WHERE salary > 75000
)
SELECT
  department,
  COUNT(*) AS headcount,
  AVG(salary) AS avg_salary
FROM high_earners
GROUP BY department
ORDER BY avg_salary DESC;

-- Same logic as a subquery (harder to read)
SELECT
  department,
  COUNT(*) AS headcount,
  AVG(salary) AS avg_salary
FROM (
  SELECT employee_name, department, salary
  FROM employees
  WHERE salary > 75000
) high_earners
GROUP BY department
ORDER BY avg_salary DESC;</code>`,

  chainCte: `<code>-- Chain multiple CTEs
WITH
  active_orders AS (
    SELECT order_id, customer_id, order_date, amount
    FROM orders
    WHERE status = 'active'
  ),
  customer_totals AS (
    SELECT
      customer_id,
      SUM(amount) AS total_spent,
      COUNT(*) AS order_count
    FROM active_orders
    GROUP BY customer_id
  ),
  top_customers AS (
    SELECT customer_id, total_spent
    FROM customer_totals
    WHERE total_spent > 5000
  )
SELECT
  c.customer_name,
  ct.total_spent,
  ct.order_count
FROM top_customers tc
JOIN customers c ON tc.customer_id = c.id
JOIN customer_totals ct ON tc.customer_id = ct.customer_id
ORDER BY ct.total_spent DESC;</code>`,

  recursiveCte: `<code>-- Recursive CTE: org chart traversal
WITH RECURSIVE org_tree AS (
  -- Base case: top-level employees (no manager)
  SELECT
    id,
    name,
    manager_id,
    name AS path,
    1 AS depth
  FROM employees
  WHERE manager_id IS NULL

  UNION ALL

  -- Recursive case: employees with a manager
  SELECT
    e.id,
    e.name,
    e.manager_id,
    ot.path || ' > ' || e.name,
    ot.depth + 1
  FROM employees e
  JOIN org_tree ot ON e.manager_id = ot.id
)
SELECT id, name, path, depth
FROM org_tree
ORDER BY path;</code>`,

  scalarSub: `<code>-- Scalar subquery in SELECT: count orders per customer
SELECT
  c.customer_name,
  (SELECT COUNT(*) FROM orders o WHERE o.customer_id = c.id) AS order_count,
  (SELECT MAX(o.order_date) FROM orders o WHERE o.customer_id = c.id) AS last_order_date
FROM customers c;

-- Scalar subquery in WHERE: customers who spent above average
SELECT customer_name, total_spent
FROM (
  SELECT
    customer_id,
    SUM(amount) AS total_spent
  FROM orders
  GROUP BY customer_id
) t
WHERE total_spent > (SELECT AVG(total) FROM (SELECT SUM(amount) AS total FROM orders GROUP BY customer_id) avg_t);</code>`,

  correlatedSub: `<code>-- Correlated subquery: employees earning above their department average
SELECT
  employee_name,
  department,
  salary
FROM employees e
WHERE salary > (
  SELECT AVG(salary)
  FROM employees
  WHERE department = e.department
);

-- EXISTS: find customers who have placed an order
SELECT c.customer_name
FROM customers c
WHERE EXISTS (
  SELECT 1
  FROM orders o
  WHERE o.customer_id = c.id
);

-- NOT EXISTS: find customers who have never ordered
SELECT c.customer_name
FROM customers c
WHERE NOT EXISTS (
  SELECT 1
  FROM orders o
  WHERE o.customer_id = c.id
);</code>`,

  cteVsView: `<code>-- CTE (session-scoped, inline)
WITH monthly_sales AS (
  SELECT
    DATE_TRUNC('month', order_date) AS month,
    SUM(amount) AS revenue
  FROM orders
  GROUP BY 1
)
SELECT * FROM monthly_sales WHERE month > '2025-01-01';

-- View (database-persisted, reusable across queries)
CREATE VIEW monthly_sales AS
SELECT
  DATE_TRUNC('month', order_date) AS month,
  SUM(amount) AS revenue
FROM orders
GROUP BY 1;

-- Materialized CTE / temp table (persisted to disk)
SELECT *
INTO #monthly_sales
FROM (
  SELECT
    DATE_TRUNC('month', order_date) AS month,
    SUM(amount) AS revenue
  FROM orders
  GROUP BY 1
) t;</code>`,

  rowsNotIn: `<code>-- Find rows in one table not in another
-- NOT IN (can fail with NULLs)
SELECT customer_name
FROM customers c
WHERE c.id NOT IN (
  SELECT customer_id FROM orders WHERE order_date > '2026-01-01'
);

-- NOT EXISTS (safer, handles NULLs)
SELECT c.customer_name
FROM customers c
WHERE NOT EXISTS (
  SELECT 1 FROM orders o
  WHERE o.customer_id = c.id
  AND o.order_date > '2026-01-01'
);

-- EXCEPT (set difference, returns distinct rows)
SELECT customer_name FROM customers
EXCEPT
SELECT c.customer_name
FROM customers c
JOIN orders o ON c.id = o.customer_id
WHERE o.order_date > '2026-01-01';</code>`,
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title="CTEs and Subqueries Explained — From Basic to Recursive | SQL Query Lab"
  description="Understand SQL CTEs, subqueries, correlated subqueries, and recursive CTEs with practical examples. Learn when to use each pattern and how they compare to views and temp tables."
  canonical="/blog/ctes-subqueries-explained"
  author={{
    name: 'Pukar Khanal',
    jobTitle: 'SQL Developer & Technical Writer',
    url: 'https://learn-sql-practice.vercel.app/authors/pukar-khanal',
    sameAs: ['https://www.linkedin.com/in/pukarkhanal/'],
  }}
  datePublished={publishDate}
  dateModified={modifiedDate}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      },
    })),
  })} />

  <article class="article">
    <header class="article-header">
      <div class="article-meta-top">
        <span class="article-category">Advanced SQL</span>
        <span class="meta-dot" aria-hidden="true">·</span>
        <time datetime={publishDate}>{formatDate(publishDate)}</time>
        <span class="meta-dot" aria-hidden="true">·</span>
        <span>Updated {formatDate(modifiedDate)}</span>
      </div>
      <h1 class="article-title">CTEs and Subqueries Explained</h1>
      <p class="article-description">
        Subqueries and Common Table Expressions (CTEs) let you build queries that go beyond
        what a single SELECT can express. This guide walks through every pattern — from
        simple scalar subqueries to recursive CTEs — with real examples you can run in your browser.
      </p>
      <div class="article-byline">
        <div class="author-avatar" aria-hidden="true"><span>PK</span></div>
        <div>
          <a href="/authors/pukar-khanal" class="author-name">Pukar Khanal</a>
          <span class="author-role">SQL Developer &amp; Technical Writer</span>
        </div>
      </div>
    </header>

    <div class="article-body">
      <p class="intro">
        Every non-trivial SQL query involves building up results from intermediate steps.
        Subqueries and CTEs give you the tools to do this cleanly. They pair well with
        <a href="/blog/sql-window-functions">window functions</a> — wrap a window function in a CTE
        to keep multi-step analytics readable. The difference between
        them is mainly syntactic — but that syntactic difference has real consequences for
        readability, reusability, and maintainability.
      </p>

      <section id="basic-subquery">
        <h2>Subqueries — Inline Computation</h2>
        <p>
          A subquery is a query nested inside another query. It can return a single value
          (scalar), a single column, or a table. The most common use is filtering or
          computing a value that depends on other rows.
        </p>
        <pre class="code-block" set:html={codeExamples.scalarSub} />
        <div class="use-case">
          <strong>Rule of thumb:</strong> If you use the same subquery logic in more than one
          place, consider a CTE. If you need it across multiple sessions, consider a view
          or a temp table.
        </div>
      </section>

      <section id="cte-basics">
        <h2>CTEs — Named Intermediate Results</h2>
        <p>
          A <strong>Common Table Expression (CTE)</strong> defines a named intermediate result
          using <code>WITH</code>, then uses it in the main query that follows. CTEs make
          multi-step queries dramatically more readable because each step has a meaningful name.
        </p>
        <pre class="code-block" set:html={codeExamples.basicCte} />
        <div class="use-case">
          <strong>Why CTEs over subqueries?</strong> The named intermediate result makes the
          query self-documenting. When you or a teammate reads this query six months later,
          <code>high_earners</code> communicates intent in a way that a nested subquery does not.
        </div>
      </section>

      <section id="chained-ctes">
        <h2>Chaining CTEs — Building Up Complexity</h2>
        <p>
          Multiple CTEs can be chained together, each building on the previous one.
          This turns a complex multi-step transformation into a series of named, readable steps.
          Each CTE can reference earlier CTEs in the same query.
        </p>
        <pre class="code-block" set:html={codeExamples.chainCte} />
        <div class="use-case">
          <strong>Best practice:</strong> Name CTEs by their output, not their input
          (<code>active_orders</code> rather than <code>filtered_orders</code>).
          If a CTE is referenced multiple times, consider materializing it as a temp table
          for performance.
        </div>
      </section>

      <section id="correlated">
        <h2>Correlated Subqueries — Per-Row Computation</h2>
        <p>
          A correlated subquery references a column from the outer query. It is evaluated
          once per row of the outer query, making it powerful — and sometimes slow.
          <code>EXISTS</code> and <code>NOT EXISTS</code> are the most common correlated patterns.
          Both require careful <a href="/blog/null-handling-sql">NULL handling</a> —
          if the correlated column contains NULLs, <code>NOT IN</code> silently returns no rows
          while <code>NOT EXISTS</code> handles them correctly.
        </p>
        <pre class="code-block" set:html={codeExamples.correlatedSub} />
        <div class="use-case warning">
          <strong>Performance warning:</strong> Correlated subqueries can be slow on large tables
          because they run the inner query for every row. Always compare the execution plan
          against a JOIN-based alternative before using them in production.
        </div>
      </section>

      <section id="recursive">
        <h2>Recursive CTEs — Traversing Hierarchies</h2>
        <p>
          A recursive CTE has two parts: a base case (where the traversal starts) and a
          recursive case (which references the CTE itself). It is the standard SQL way to
          traverse trees — org charts, file systems, bill-of-materials, and category hierarchies.
        </p>
        <pre class="code-block" set:html={codeExamples.recursiveCte} />
        <div class="use-case">
          <strong>Important:</strong> Always include a termination condition — typically
          <code>WHERE manager_id IS NULL</code> for the base case and a depth limit
          (<code>WHERE depth &lt; 50</code>) to prevent infinite loops if the data has cycles.
        </div>
      </section>

      <section id="not-in-exists">
        <h2>NOT IN vs NOT EXISTS vs EXCEPT</h2>
        <p>
          Finding rows that do not have a match in another table is a common task, but the
          three approaches behave very differently when NULLs are involved. Understanding
          the distinction prevents subtle bugs.
        </p>
        <pre class="code-block" set:html={codeExamples.rowsNotIn} />
        <div class="use-case warning">
          <strong>Critical gotcha:</strong> <code>NOT IN</code> with a subquery that contains
          NULL values returns no rows at all. Always use <code>NOT EXISTS</code> or <code>EXCEPT</code>
          for finding rows not in another table — they handle NULLs correctly.
        </div>
      </section>

      <section id="cte-vs-view">
        <h2>CTE vs View vs Temp Table</h2>
        <p>
          CTEs, views, and temp tables all serve as named intermediate results, but they differ
          in scope, persistence, and reusability. Choose the right one for the context.
        </p>
        <pre class="code-block" set:html={codeExamples.cteVsView} />
        <div class="use-case">
          <strong>Quick decision guide:</strong> Use a CTE for one-off exploratory queries.
          Use a view for logic you need across many queries and sessions.
          Use a temp table (#) when the intermediate result is large and referenced multiple times
          in the same procedure.
        </div>
      </section>

      <section id="faq" class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqItems.map((item) => (
            <>
              <dt class="faq-question">{item.question}</dt>
              <dd class="faq-answer">{item.answer}</dd>
            </>
          ))}
        </dl>
      </section>

      <aside class="practice-cta">
        <h2>Practice CTEs and subqueries in your browser</h2>
        <p>
          Run all the examples above against real database tables in SQL Query Lab.
          Practice scalar subqueries, correlated subqueries, chained CTEs, and recursive
          queries — no setup, no installs, no sample data to load.
        </p>
        <a href="https://learn-sql-practice.vercel.app/" class="cta-btn">
          Start practicing CTEs and subqueries
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </aside>
    </div>
  </article>
</Layout>

<style>
  .article { max-width: 68ch; }

  .article-body section {
    margin-bottom: 3rem;
  }

  .article-body section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .article-body section p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .code-block {
    background: #1a1a2e;
    border: 1px solid #2a2a4a;
    border-radius: 0.5rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 0 0 1.25rem;
    font-size: 0.875rem;
    line-height: 1.65;
    color: #e2e8f0;
  }

  .code-block code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: inherit;
    color: inherit;
  }

  .use-case {
    padding: 0.875rem 1rem;
    border-left: 3px solid var(--color-primary);
    background: var(--color-surface);
    border-radius: 0 0.375rem 0.375rem 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .use-case.warning {
    border-left-color: #f59e0b;
    background: #fffbeb;
  }

  :global(.dark) .use-case.warning {
    background: #292524;
    border-left-color: #f59e0b;
    color: #fef3c7;
  }

  .use-case strong {
    font-weight: 600;
  }

  .use-case code {
    font-size: 0.875em;
    background: var(--color-surface);
    padding: 0.1em 0.3em;
    border-radius: 0.25rem;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  .faq-section {
    margin-bottom: 3rem;
  }

  .faq-section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    letter-spacing: -0.01em;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-question {

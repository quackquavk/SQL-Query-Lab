---
import Layout from '../../layouts/Layout.astro';

const publishDate = '2026-05-05';
const modifiedDate = '2026-05-20';

const faqItems = [
  {
    question: 'Should I use SELECT * or list specific columns?',
    answer: 'Always list specific columns. SELECT * retrieves unnecessary data, breaks when columns are added/removed/reordered, exposes sensitive columns unintentionally, and makes intent unclear. It also prevents the database from using covering indexes effectively.',
  },
  {
    question: 'How do I prevent SQL injection?',
    answer: 'Always use parameterized queries or prepared statements. Never concatenate user input directly into SQL strings. Most ORMs and database drivers provide parameterized query APIs — use them exclusively. Input validation is a secondary defense, not a primary one.',
  },
  {
    question: 'When should I add an index?',
    answer: 'Add an index when: (1) the column is frequently used in WHERE, JOIN, or ORDER BY clauses, (2) the table is large and the query returns a small percentage of rows, and (3) the column has high cardinality (many distinct values). Do not over-index — each index slows down INSERT/UPDATE/DELETE operations. <a href="/blog/sql-indexing-performance">See the full indexing guide</a> for composite indexes, covering indexes, and execution plan analysis.',
  },
  {
    question: 'What is the most important query optimization technique?',
    answer: 'Write queries that match your indexes. The most impactful optimizations are: (1) filter early with WHERE clauses before joins, (2) use indexed columns in JOIN and WHERE conditions, (3) avoid functions on indexed columns in WHERE, and (4) use covering indexes for frequently-run queries.',
  },
];

const codeExamples = {
  caseStyle: `<code>-- Good
SELECT employee_id, first_name, last_name
FROM employees
WHERE department_id = 5
  AND hire_date > '2024-01-01'
ORDER BY last_name, first_name;

-- Bad — hard to distinguish keywords from identifiers
select employee_id, first_name, last_name
from employees
where department_id = 5;</code>`,

  clauseAlign: `<code>-- Good — conditions are grouped and readable
SELECT o.order_id, o.total
FROM orders o
JOIN customers c ON o.customer_id = c.id
WHERE c.region = 'West'
  AND o.status IN ('pending', 'processing')
  AND o.created_at > DATEADD(day, -30, GETDATE());

-- Bad — one long line is unreadable
WHERE c.region = 'West' AND o.status IN ('pending', 'processing')
  AND o.created_at > DATEADD(day, -30, GETDATE());</code>`,

  aliases: `<code>-- Good — aliases are clear and consistent
SELECT o.order_id, c.customer_name
FROM orders o
JOIN customers c ON o.customer_id = c.id;

-- Bad — no aliases forces full table names everywhere
SELECT orders.order_id, customers.customer_name
FROM orders
JOIN customers ON orders.customer_id = customers.id;</code>`,

  naming: `<code>-- Table names: plural, snake_case
-- Columns: singular, snake_case
-- Primary keys: table_singular_id (employee_id)
-- Foreign keys: referenced_table_singular_id (department_id)
-- Indexes: idx_table_column(s) (idx_employees_department_id)

-- Tables
CREATE TABLE employees (
  employee_id INT PRIMARY KEY,
  first_name VARCHAR(100) NOT NULL,
  last_name VARCHAR(100) NOT NULL,
  department_id INT,
  created_at DATETIME DEFAULT GETDATE(),
  CONSTRAINT fk_employees_department
    FOREIGN KEY (department_id) REFERENCES departments(department_id)
);

-- Indexes
CREATE INDEX idx_employees_department_id ON employees(department_id);
CREATE INDEX idx_employees_name ON employees(last_name, first_name);</code>`,

  reservedWords: `<code>-- Good
order_date    -- not "date"
order_number  -- not "order"
user_name     -- not "user"

-- Bad
date          -- reserved word in most SQL dialects
user          -- reserved in many systems</code>`,

  injection: `<code>-- GOOD — parameters are safe
const query = \`
  SELECT * FROM users
  WHERE email = @Email AND status = @Status
\`;
await db.query(query, { Email: userEmail, Status: 'active' });

-- BAD — string concatenation creates injection vulnerability
const query = \`
  SELECT * FROM users
  WHERE email = '\${userEmail}' AND status = 'active'
\`;
-- If userEmail = "' OR '1'='1", this returns all users</code>`,

  privileges: `<code>-- Application account: read + write, no DDL
GRANT SELECT, INSERT, UPDATE, DELETE ON SCHEMA::dbo TO app_user;
DENY ALTER ON SCHEMA::dbo TO app_user;

-- Reporting account: read only
GRANT SELECT ON SCHEMA::dbo TO report_reader;</code>`,

  filterFirst: `<code>-- Good — filter first, then join (fewer rows to join)
SELECT o.order_id, c.customer_name
FROM orders o
JOIN customers c ON o.customer_id = c.id
WHERE o.status = 'pending'
  AND c.region = 'West';

-- Less efficient — joins first, then filters
SELECT o.order_id, c.customer_name
FROM orders o
JOIN customers c ON o.customer_id = c.id
WHERE c.region = 'West';</code>`,

  noFunctions: `<code>-- Bad — function on column prevents index use
WHERE YEAR(created_at) = 2025
WHERE LOWER(email) = 'john@example.com'

-- Good — function on the constant, column is raw
WHERE created_at >= '2025-01-01' AND created_at < '2026-01-01'
WHERE email = 'john@example.com'</code>`,

  existsVsIn: `<code>-- Better: EXISTS stops at first match
SELECT e.name
FROM employees e
WHERE EXISTS (
  SELECT 1 FROM departments d WHERE d.id = e.dept_id AND d.active = 1
);

-- IN collects all matching values first (can be slower)
SELECT e.name
FROM employees e
WHERE e.dept_id IN (
  SELECT id FROM departments WHERE active = 1
);</code>`,

  selectStar: `<code>-- Good — explicit columns, predictable
SELECT order_id, customer_id, total, status, created_at
FROM orders
WHERE status = 'pending';

-- Bad — returns all columns (including potentially sensitive ones)
SELECT * FROM orders WHERE status = 'pending';</code>`,

  cteExample: `<code>-- Good — readable, named steps
WITH active_customers AS (
  SELECT id, name, region
  FROM customers
  WHERE status = 'active'
),
recent_orders AS (
  SELECT customer_id, MAX(order_date) AS last_order_date
  FROM orders
  GROUP BY customer_id
)
SELECT
  c.name,
  c.region,
  o.last_order_date,
  DATEDIFF(day, o.last_order_date, GETDATE()) AS days_since_order
FROM active_customers c
JOIN recent_orders o ON c.id = o.customer_id
WHERE DATEDIFF(day, o.last_order_date, GETDATE()) > 90;</code>`,

  comments: `<code>-- Good: explains business reasoning
-- Using 30-day window per contract terms (SLA section 4.2)
-- Excluding cancelled orders per Q3 revenue reporting policy
WHERE order_date >= DATEADD(day, -30, GETDATE())
  AND status != 'cancelled'

-- Bad: just restates the code
-- Get orders from the last 30 days
WHERE order_date >= DATEADD(day, -30, GETDATE())</code>`,

  nullHandling: `<code>-- Explicit NULL check
WHERE manager_id IS NOT NULL

-- Provide default at output boundary (not in WHERE)
SELECT
  employee_name,
  COALESCE(manager_name, '(no manager)') AS manager_name
FROM employees;

-- Be explicit about NULL behavior in comparisons
-- = NULL never matches, use IS NULL instead
WHERE department_id = 5
WHERE department_id IS NULL</code>`,
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title="SQL Best Practices — Writing Clean, Fast, Maintainable Queries | SQL Query Lab"
  description="From formatting and naming conventions to indexing strategy and query optimization — a practical guide to writing SQL that your team can read, maintain, and that performs in production."
  canonical="/blog/sql-best-practices"
  author={{
    name: 'Pukar Khanal',
    jobTitle: 'SQL Developer & Technical Writer',
    url: 'https://learn-sql-practice.vercel.app/authors/pukar-khanal',
    sameAs: ['https://www.linkedin.com/in/pukarkhanal/'],
  }}
  datePublished={publishDate}
  dateModified={modifiedDate}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      },
    })),
  })} />

  <article class="article">
    <header class="article-header">
      <div class="article-meta-top">
        <span class="article-category">Best Practices</span>
        <span class="meta-dot" aria-hidden="true">·</span>
        <time datetime={publishDate}>{formatDate(publishDate)}</time>
        <span class="meta-dot" aria-hidden="true">·</span>
        <span>Updated {formatDate(modifiedDate)}</span>
      </div>
      <h1 class="article-title">SQL Best Practices</h1>
      <p class="article-description">
        The practical rules that separate maintainable SQL from unmaintainable SQL —
        covering formatting, naming, security, performance, and the patterns that
        actually matter in production codebases.
      </p>
      <div class="article-byline">
        <div class="author-avatar" aria-hidden="true"><span>PK</span></div>
        <div>
          <a href="/authors/pukar-khanal" class="author-name">Pukar Khanal</a>
          <span class="author-role">SQL Developer &amp; Technical Writer</span>
        </div>
      </div>
    </header>

    <div class="article-body">
      <p class="intro">
        SQL is read far more often than it is written. A query that is clear to the author
        today will be incomprehensible to the author's teammates — or to the author in six months —
        without consistent formatting and naming. This guide covers the practices that make SQL
        genuinely maintainable at scale.
      </p>

      <section id="formatting">
        <h2>Formatting &amp; Style</h2>

        <div class="rule-block">
          <h3>1. Uppercase keywords, lowercase names</h3>
          <p>
            This convention has been standard in SQL for decades. It immediately distinguishes
            keywords from identifiers when scanning a query.
          </p>
          <pre class="code-block" set:html={codeExamples.caseStyle} />
        </div>

        <div class="rule-block">
          <h3>2. One clause per line, keywords aligned</h3>
          <p>
            Line up AND/OR with the WHERE keyword for clear visual grouping of conditions.
            Break complex WHERE clauses into parenthesized groups.
          </p>
          <pre class="code-block" set:html={codeExamples.clauseAlign} />
        </div>

        <div class="rule-block">
          <h3>3. Always use table aliases with meaningful abbreviations</h3>
          <p>
            Aliases make queries shorter and are required for self-joins. Use meaningful
            abbreviations (o for orders, c for customers) consistent across your codebase.
          </p>
          <pre class="code-block" set:html={codeExamples.aliases} />
        </div>
      </section>

      <section id="naming">
        <h2>Naming Conventions</h2>

        <div class="rule-block">
          <h3>4. Consistent naming patterns</h3>
          <p>Pick a convention and apply it consistently across the entire database.</p>
          <pre class="code-block" set:html={codeExamples.naming} />
        </div>

        <div class="rule-block">
          <h3>5. Avoid reserved words as column names</h3>
          <p>
            Columns named <code>date</code>, <code>order</code>, <code>group</code>, <code>user</code>,
            and <code>level</code> cause quoting issues in some databases and confusion everywhere.
            Prefix with the entity name.
          </p>
          <pre class="code-block" set:html={codeExamples.reservedWords} />
        </div>
      </section>

      <section id="security">
        <h2>Security</h2>

        <div class="rule-block warning">
          <h3>6. Always use parameterized queries — never concatenate user input</h3>
          <p>
            SQL injection is the most dangerous and preventable web vulnerability.
            Parameterized queries separate SQL logic from data, making injection impossible.
          </p>
          <pre class="code-block" set:html={codeExamples.injection} />
        </div>

        <div class="rule-block">
          <h3>7. Apply the principle of least privilege</h3>
          <p>
            Application database accounts should have only the permissions they need —
            not <code>db_owner</code>. Use separate read-only accounts for reporting queries.
          </p>
          <pre class="code-block" set:html={codeExamples.privileges} />
        </div>
      </section>

      <section id="performance">
        <h2>Performance</h2>

        <div class="rule-block">
          <h3>8. Filter before you join</h3>
          <p>
            Apply WHERE conditions early to reduce the number of rows before joins.
            This reduces the amount of data the database must process.
          </p>
          <pre class="code-block" set:html={codeExamples.filterFirst} />
        </div>

        <div class="rule-block">
          <h3>9. Avoid functions on indexed columns in WHERE clauses</h3>
          <p>
            Wrapping a column in a function prevents the optimizer from using an index.
            Rewrite to put the function on the comparison value instead.
          </p>
          <pre class="code-block" set:html={codeExamples.noFunctions} />
        </div>

        <div class="rule-block">
          <h3>10. Use EXISTS instead of IN for subqueries when possible</h3>
          <p>
            <code>EXISTS</code> stops as soon as it finds one match. <code>IN</code> must
            collect all matching values first. For large subqueries, this is a significant difference.
          </p>
          <pre class="code-block" set:html={codeExamples.existsVsIn} />
        </div>

        <div class="rule-block">
          <h3>11. Select only what you need — never use SELECT *</h3>
          <p>
            Listing specific columns reduces network transfer, allows better index usage,
            and makes your queries self-documenting.
          </p>
          <pre class="code-block" set:html={codeExamples.selectStar} />
        </div>
      </section>

      <section id="maintainability">
        <h2>Maintainability</h2>

        <div class="rule-block">
          <h3>12. Use CTEs for complex logic — not deeply nested subqueries</h3>
          <p>
            CTEs (Common Table Expressions) named with <code>WITH</code> read top-to-bottom,
            making multi-step logic much easier to follow than nested subqueries.
          </p>
          <pre class="code-block" set:html={codeExamples.cteExample} />
        </div>

        <div class="rule-block">
          <h3>13. Comment the why, not the what</h3>
          <p>
            Good SQL comments explain business logic, unusual requirements, or why a
            non-obvious approach was chosen — not what the code does (that is obvious from the code).
          </p>
          <pre class="code-block" set:html={codeExamples.comments} />
        </div>

        <div class="rule-block">
          <h3>14. Handle NULLs explicitly — do not rely on defaults</h3>
          <p>
            NULL comparisons always return NULL (unknown), not true or false. Use
            <code>IS NULL</code>/<code>IS NOT NULL</code> explicitly and wrap potentially
            NULL columns with <code>COALESCE</code> at the output boundary.
          </p>
          <pre class="code-block" set:html={codeExamples.nullHandling} />
        </div>
      </section>

      <section id="faq" class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqItems.map((item) => (
            <>
              <dt class="faq-question">{item.question}</dt>
              <dd class="faq-answer">{item.answer}</dd>
            </>
          ))}
        </dl>
      </section>

      <aside class="practice-cta">
        <h2>Practice these patterns in SQL Query Lab</h2>
        <p>
          Run all the examples in this guide with real database schemas.
          Write your own queries following these conventions and validate them instantly.
        </p>
        <a href="https://learn-sql-practice.vercel.app/" class="cta-btn">
          Open SQL Query Lab
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </aside>
    </div>
  </article>
</Layout>

<style>
  .article { max-width: 68ch; }
  :global(main) { max-width: 80ch !important; }

  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-meta-top {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .article-category {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-primary);
    color: white;
    padding: 0.2rem 0.5rem;
    border-radius: 0.2rem;
  }

  .meta-dot { opacity: 0.4; }

  .article-title {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }

  .article-description {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
    line-height: 1.65;
  }

  .article-byline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--color-primary) 0%, #7c3aed 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-avatar span {
    font-size: 0.875rem;
    font-weight: 700;
    color: white;
  }

  .author-name {
    display: block;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .author-name:hover { color: var(--color-primary); }

  .author-role {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .article-body { line-height: 1.75; }

  .intro {
    font-size: 1.0625rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  section { margin-bottom: 3rem; }

  section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border);
  }

  .rule-block {
    margin-bottom: 2rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .rule-block h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    margin: 0 0 0.625rem;
    color: var(--color-text);
  }

  .rule-block h3 code {
    background: rgba(37, 99, 235, 0.1);
    padding: 0.1rem 0.3rem;
    border-radius: 0.2rem;
    font-size: 0.875em;
    color: var(--color-primary);
  }

  .rule-block > p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
    line-height: 1.6;
  }

  .rule-block.warning {
    background: rgba(245, 158, 11, 0.06);
    border-color: rgba(245, 158, 11, 0.3);
  }

  .rule-block.warning h3 { color: #b45309; }

  @media (prefers-color-scheme: dark) {
    .rule-block.warning h3 { color: #fbbf24; }
  }

  .code-block {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 1rem 1.125rem;
    border-radius: 0.375rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    margin: 0;
    white-space: pre;
  }

  /* FAQ */
  .faq-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .faq-section h2 {
    border: none;
    padding: 0;
    margin-bottom: 1.25rem;
    font-size: 1.25rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-question {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .faq-answer {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* CTA */
  .practice-cta {
    background: linear-gradient(135deg, var(--color-primary) 0%, #7c3aed 100%);
    border-radius: 0.625rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .practice-cta h2 {
    color: white;
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
    border: none;
    padding: 0;
  }

  .practice-cta p {
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 52ch;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: white;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.9375rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: transform 0.15s;
  }

  .cta-btn:hover { transform: translateY(-1px); }

  @media (max-width: 640px) {
    .article-title { font-size: 1.75rem; }
  }
</style>

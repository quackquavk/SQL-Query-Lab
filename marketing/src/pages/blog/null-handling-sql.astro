---
import Layout from '../../layouts/Layout.astro';

const publishDate = '2026-05-28';
const modifiedDate = '2026-06-02';

const faqItems = [
  {
    question: 'Why does NULL = NULL not return TRUE in SQL?',
    answer: 'NULL represents an unknown or missing value, not a zero or empty string. Comparing an unknown to another unknown produces an unknown (NULL), not TRUE — because we cannot assert that two unknown values are equal. This is the foundational principle of three-valued logic in SQL.',
  },
  {
    question: 'What is the difference between COALESCE and IFNULL?',
    answer: 'COALESCE accepts any number of arguments and returns the first non-NULL value from the list. IFNULL accepts exactly two arguments and returns the second if the first is NULL. COALESCE is more versatile (any number of arguments); IFNULL is slightly faster for the two-argument case in some databases.',
  },
  {
    question: 'When should I use NULLIF instead of COALESCE?',
    answer: 'Use NULLIF when you want to treat a specific sentinel value (like 0 or an empty string) as NULL — typically to avoid division-by-zero errors or to handle placeholder values in legacy data. Use COALESCE when you want to provide a fallback value for any NULL.',
  },
  {
    question: 'How does NULL affect GROUP BY and ORDER BY?',
    answer: 'In most SQL databases, NULL values group together as a single group (NULL = NULL in GROUP BY). In ORDER BY, NULL sorts either first or last depending on the database — use NULLS FIRST or NULLS LAST to control it explicitly. SQL Server sorts NULLs first by default; PostgreSQL sorts NULLs last.',
  },
  {
    question: 'How do I count non-NULL values vs all rows?',
    answer: 'COUNT(column_name) counts only non-NULL values. COUNT(*) counts all rows including NULLs. To count non-NULL values explicitly, use COUNT(column) or COUNTIF(column IS NOT NULL) in databases that support it. The difference matters when columns contain NULLs.',
  },
];

const codeExamples = {
  isNull: `<code>-- Check for NULL: always use IS NULL or IS NOT NULL
-- The = operator does NOT work with NULL
SELECT *
FROM employees
WHERE manager_id = NULL;           -- WRONG: always returns 0 rows!

SELECT *
FROM employees
WHERE manager_id IS NULL;          -- CORRECT: finds rows with no manager

SELECT *
FROM employees
WHERE manager_id IS NOT NULL;      -- CORRECT: finds rows with a manager</code>`,

  coalesce: `<code>-- COALESCE: return first non-NULL value
SELECT
  employee_name,
  COALESCE(phone, email, 'No contact info') AS contact_info
FROM employees;

-- IFNULL: two-argument shortcut (MySQL, SQLite, PostgreSQL)
SELECT
  employee_name,
  IFNULL(phone, 'No phone') AS phone_number
FROM employees;

-- NVL: Oracle's two-argument equivalent
SELECT
  employee_name,
  NVL(phone, 'No phone') AS phone_number
FROM employees;

-- Nested COALESCE for multiple fallbacks
SELECT
  product_name,
  COALESCE(
    discount_price,
    sale_price,
    list_price,
    0
  ) AS effective_price
FROM products;</code>`,

  nullif: `<code>-- NULLIF: return NULL if two values are equal
-- Prevents division by zero
SELECT
  product_name,
  total_revenue / NULLIF(total_quantity, 0) AS avg_price_per_unit
FROM products;
-- Without NULLIF: division by zero returns error
-- With NULLIF: returns NULL instead of error when quantity is 0

-- Treat empty string as NULL
SELECT
  employee_name,
  NULLIF(phone_number, '') AS phone
FROM employees;
-- Empty strings become NULL, COALESCE can then provide a default

-- Practical: avoid "divide by zero" in percentage calculations
SELECT
  region,
 100.0 * sold / NULLIF(total_inventory, 0) AS sell_through_pct
FROM inventory;</code>`,

  threeValued: `<code>-- Three-valued logic: TRUE, FALSE, and UNKNOWN (NULL)
-- Comparison with NULL always yields UNKNOWN

SELECT 1 = 1;           -- TRUE
SELECT 1 = 2;           -- FALSE
SELECT 1 = NULL;        -- UNKNOWN (not FALSE!)
SELECT NULL = NULL;     -- UNKNOWN (not TRUE!)

-- UNKNOWN is filtered out by WHERE (only TRUE passes)
SELECT *
FROM employees
WHERE department_id = 5;
-- Rows where department_id IS NULL are excluded (UNKNOWN != TRUE)

-- IS DISTINCT FROM: NULL-safe comparison (PostgreSQL, SQLite)
SELECT *
FROM employees
WHERE manager_id IS DISTINCT FROM 1234;
-- Returns rows where manager_id = 1234 OR manager_id IS NULL</code>`,

  countNulls: `<code>-- COUNT(*) vs COUNT(column) — critical difference
SELECT
  COUNT(*) AS total_rows,           -- all rows, including NULLs
  COUNT(phone) AS with_phone,       -- only non-NULL phone values
  COUNT(*) - COUNT(phone) AS without_phone  -- rows with NULL phone
FROM employees;

-- Count NULLs in a specific column
SELECT
  COUNT(*) - COUNT(manager_id) AS null_manager_count
FROM employees;

-- SUM with NULL handling
SELECT
  SUM(bonus) AS total_bonus,        -- ignores NULLs
  SUM(COALESCE(bonus, 0)) AS total_incl_zero  -- treats NULL as 0
FROM employees;
-- SUM(bonus) with NULL rows: NULL rows contribute 0 to the sum
-- but the row is still counted</code>`,

  caseNull: `<code>-- CASE expressions with NULL
-- CASE ELSE NULL: be explicit about what happens with NULLs

-- Long form: explicit NULL handling
SELECT
  employee_name,
  CASE
    WHEN bonus IS NULL THEN 'No bonus'
    WHEN bonus < 500 THEN 'Low bonus'
    WHEN bonus >= 500 THEN 'High bonus'
  END AS bonus_category
FROM employees;

-- Short form: COALESCE in CASE
SELECT
  employee_name,
  CASE
    WHEN COALESCE(bonus, 0) < 500 THEN 'Low bonus'
    ELSE 'High bonus'
  END AS bonus_category
FROM employees;

-- NULLIF inside CASE
SELECT
  employee_name,
  CASE
    WHEN NULLIF(orders_count, 0) < 5 THEN 'Low volume'
    ELSE 'Active'
  END AS customer_status
FROM customers;</code>`,

  strings: `<code>-- NULL in string concatenation: use CONCAT or IFNULL
SELECT
  first_name || ' ' || last_name AS full_name
FROM users;
-- If first_name or last_name is NULL, the whole result is NULL!

-- CONCAT ignores NULL arguments (standard SQL)
SELECT
  CONCAT(first_name, ' ', last_name) AS full_name
FROM users;
-- If first_name is NULL, returns just last_name (no trailing space)

-- MySQL: IFNULL for string concatenation
SELECT
  CONCAT(IFNULL(first_name, ''), ' ', IFNULL(last_name, '')) AS full_name
FROM users;

-- PostgreSQL: COALESCE in concatenation
SELECT
  COALESCE(first_name, '') || ' ' || COALESCE(last_name, '') AS full_name
FROM users;</code>`,

  aggregateWithNull: `<code>-- Aggregates ignore NULLs by default
SELECT
  AVG(salary) AS avg_salary,    -- ignores NULL salaries
  MAX(bonus) AS max_bonus,     -- ignores NULL bonuses
  MIN(bonus) AS min_bonus       -- ignores NULL bonuses
FROM employees;

-- AVG of a column with NULLs: same as AVG of non-NULL values
-- The NULL rows are simply not included in the calculation

-- To treat NULL as a specific value, use COALESCE inside aggregate
SELECT
  AVG(COALESCE(years_experience, 0)) AS avg_exp_incl_zero
FROM employees;
-- This counts NULL experience as 0 years, lowering the average

-- COUNT with DISTINCT and NULL
SELECT
  COUNT(DISTINCT department_id) AS distinct_depts
FROM employees;
-- NULL department is a distinct value — it counts as 1 distinct value</code>`,
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title="NULL Handling in SQL — IS NULL, COALESCE, NULLIF, and Three-Valued Logic | SQL Query Lab"
  description="Master NULL handling in SQL: IS NULL, COALESCE, IFNULL, NULLIF, string concatenation with NULLs, three-valued logic, and aggregate functions with NULLs. Every example is runnable in your browser."
  canonical="/blog/null-handling-sql"
  author={{
    name: 'Pukar Khanal',
    jobTitle: 'SQL Developer & Technical Writer',
    url: 'https://learn-sql-practice.vercel.app/authors/pukar-khanal',
    sameAs: ['https://www.linkedin.com/in/pukarkhanal/'],
  }}
  datePublished={publishDate}
  dateModified={modifiedDate}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      },
    })),
  })} />

  <article class="article">
    <header class="article-header">
      <div class="article-meta-top">
        <span class="article-category">Fundamentals</span>
        <span class="meta-dot" aria-hidden="true">·</span>
        <time datetime={publishDate}>{formatDate(publishDate)}</time>
        <span class="meta-dot" aria-hidden="true">·</span>
        <span>Updated {formatDate(modifiedDate)}</span>
      </div>
      <h1 class="article-title">NULL Handling in SQL</h1>
      <p class="article-description">
        NULL is not zero, not an empty string, and not "nothing." It is the marker for
        an unknown or missing value — and SQL's three-valued logic makes working with
        it tricky if you do not understand it. This guide covers every NULL operator,
        function, and pattern you need to write correct queries.
      </p>
      <div class="article-byline">
        <div class="author-avatar" aria-hidden="true"><span>PK</span></div>
        <div>
          <a href="/authors/pukar-khanal" class="author-name">Pukar Khanal</a>
          <span class="author-role">SQL Developer &amp; Technical Writer</span>
        </div>
      </div>
    </header>

    <div class="article-body">
      <p class="intro">
        NULL causes more unexpected query results than any other SQL feature.
        Window functions, CTEs, and subqueries all interact with NULLs in subtle ways —
        understanding <a href="/blog/sql-window-functions">how window functions handle NULLs</a>
        in their frames and <a href="/blog/ctes-subqueries-explained">how correlated subqueries
        treat NULLs in EXISTS clauses</a> is essential for correct analytics.
        A query that works on your test data starts returning wrong results when
        real data arrives with NULL values. The fix is not to patch queries after
        the fact — it is to internalize how NULL behaves in comparisons,
        concatenations, aggregations, and CASE expressions from the start.
      </p>

      <section id="is-null">
        <h2>Checking for NULL — IS NULL and IS NOT NULL</h2>
        <p>
          The <code>=</code> operator returns neither TRUE nor FALSE when one operand
          is NULL — it returns UNKNOWN. This means <code>WHERE column = NULL</code>
          never matches anything, even rows where the column is NULL. Always use
          <code>IS NULL</code> or <code>IS NOT NULL</code>.
        </p>
        <pre class="code-block" set:html={codeExamples.isNull} />
        <div class="use-case warning">
          <strong>Silent bug:</strong> <code>WHERE column = NULL</code> does not raise
          an error — it simply returns no rows. This silent failure is the most
          dangerous aspect of three-valued logic. Always run <code>IS NULL</code>
          checks during development and testing.
        </div>
      </section>

      <section id="coalesce">
        <h2>COALESCE and IFNULL — Providing Fallback Values</h2>
        <p>
          <code>COALESCE(a, b, c, ...)</code> returns the first non-NULL argument.
          It is the standard SQL way to handle NULLs in expressions. <code>IFNULL(a, b)</code>
          is a two-argument shorthand available in MySQL, SQLite, and PostgreSQL.
          <code>NVL(a, b)</code> is Oracle's equivalent.
        </p>
        <pre class="code-block" set:html={codeExamples.coalesce} />
        <div class="use-case">
          <strong>Pattern:</strong> <code>COALESCE(nullable_column, default_value)</code>
          is the go-to for displaying NULLs as a readable fallback. Nest them for
          multiple fallbacks: <code>COALESCE(price, sale_price, list_price, 0)</code>.
        </div>
      </section>

      <section id="nullif">
        <h2>NULLIF — Treating a Value as NULL</h2>
        <p>
          <code>NULLIF(a, b)</code> returns NULL if <code>a</code> equals <code>b</code>,
          otherwise returns <code>a</code>. Its most valuable use is preventing
          division by zero — when the divisor could be zero, wrapping it in
          <code>NULLIF(divisor, 0)</code> converts the zero to NULL, and division
          by NULL returns NULL instead of an error.
        </p>
        <pre class="code-block" set:html={codeExamples.nullif} />
        <div class="use-case">
          <strong>Division by zero pattern:</strong>
          <code>total / NULLIF(count, 0)</code> is idiomatic SQL. It is cleaner than
          <code>CASE WHEN count = 0 THEN NULL ELSE total / count END</code> and works
          correctly even when count is NULL (returns NULL rather than error).
        </div>
      </section>

      <section id="three-valued">
        <h2>Three-Valued Logic — The Root of the Confusion</h2>
        <p>
          SQL uses three-valued logic: TRUE, FALSE, and UNKNOWN (which is represented
          as NULL). Every comparison with NULL produces UNKNOWN, not FALSE.
          A <code>WHERE</code> clause only returns rows where the condition evaluates
          to TRUE — UNKNOWN rows are excluded.
        </p>
        <pre class="code-block" set:html={codeExamples.threeValued} />
        <div class="use-case">
          <strong>IS DISTINCT FROM</strong> is a NULL-safe comparison operator available
          in PostgreSQL, SQLite, and some other databases. <code>A IS DISTINCT FROM B</code>
          returns TRUE if A and B have different values, including when one or both are NULL.
          It is equivalent to <code>(A <> B) OR (A IS NULL AND B IS NOT NULL) OR (A IS NOT NULL AND B IS NULL)</code>
          but written much more readably.
        </div>
      </section>

      <section id="counting">
        <h2>Aggregates and NULL — COUNT, SUM, AVG</h2>
        <p>
          Aggregate functions ignore NULLs by default — <code>COUNT(column)</code> counts
          only non-NULL values, <code>AVG(column)</code> averages only non-NULL values.
          <code>COUNT(*)</code> is the exception: it counts all rows including NULLs.
          Understanding this distinction prevents off-by-one errors in reports.
        </p>
        <pre class="code-block" set:html={codeExamples.countNulls} />
        <div class="use-case">
          <strong>Tip:</strong> To count rows where a column is NULL:
          <code>SELECT COUNT(*) - COUNT(column) FROM table</code>.
          This works because <code>COUNT(*)</code> counts all rows while
          <code>COUNT(column)</code> counts non-NULL values — their difference is
          the NULL count.
        </div>
      </section>

      <section id="strings">
        <h2>String Concatenation with NULL</h2>
        <p>
          String concatenation with <code>||</code> (SQL standard) or <code>+</code> (SQL Server)
          returns NULL if any operand is NULL. This is a common source of blank-looking
          names and addresses. Use <code>CONCAT()</code> (which ignores NULL arguments) or
          wrap each nullable operand with <code>COALESCE(value, '')</code>.
        </p>
        <pre class="code-block" set:html={codeExamples.strings} />
        <div class="use-case warning">
          <strong>SQL Server gotcha:</strong> <code>SET CONCAT_NULL_YIELDS_NULL ON</code>
          is the default. In SQL Server, <code>'hello' + NULL</code> returns NULL.
          In PostgreSQL/MySQL with <code>||</code>, the same happens. Always test
          concatenation with NULL test data, not just with populated rows.
        </div>
      </section>

      <section id="case-null">
        <h2>CASE Expressions and NULL</h2>
        <p>
          <code>CASE</code> expressions treat NULL as a distinct value. Use
          <code>WHEN column IS NULL</code> (not <code>WHEN column = NULL</code>)
          to match NULL in a <code>WHEN</code> clause. When a <code>THEN</code> or
          <code>ELSE</code> is not specified, the default result is NULL.
        </p>
        <pre class="code-block" set:html={codeExamples.caseNull} />
        <div class="use-case">
          <strong>Pattern:</strong> Explicit NULL handling in CASE is often cleaner
          than COALESCE for multi-branch logic:
          <code>CASE WHEN value IS NULL THEN 'missing' WHEN value < threshold THEN 'low' ELSE 'ok' END</code>
          is more readable than nesting COALESCE calls.
        </div>
      </section>

      <section id="faq" class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqItems.map((item) => (
            <>
              <dt class="faq-question">{item.question}</dt>
              <dd class="faq-answer">{item.answer}</dd>
            </>
          ))}
        </dl>
      </section>

      <aside class="practice-cta">
        <h2>Practice NULL handling in your browser</h2>
        <p>
          Run all the examples above in SQL Query Lab. Practice IS NULL, COALESCE,
          NULLIF, three-valued logic, and aggregate functions with NULL values —
          no setup, no installs, no sample data to load.
        </p>
        <a href="https://learn-sql-practice.vercel.app/" class="cta-btn">
          Start practicing NULL handling
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </aside>
    </div>
  </article>
</Layout>


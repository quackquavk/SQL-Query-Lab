      background: #292524;
      border-left-color: #f59e0b;
      color: #fef3c7;
    }
  }

  .use-case strong {
    font-weight: 600;
  }

  .use-case code {
    font-size: 0.875em;
    background: var(--color-surface);
    padding: 0.1em 0.3em;
    border-radius: 0.25rem;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  .faq-section {
    margin-bottom: 3rem;
  }

  .faq-section h2 {
    font-size: 1.5rem;
    font-weight: 700;

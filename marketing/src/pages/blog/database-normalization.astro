    color: #e2e8f0;
  }

  .code-block code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: inherit;
    color: inherit;
  }

  .use-case {
    padding: 0.875rem 1rem;
    border-left: 3px solid var(--color-primary);
    background: var(--color-surface);
    border-radius: 0 0.375rem 0.375rem 0;
    font-size: 0.9375rem;
